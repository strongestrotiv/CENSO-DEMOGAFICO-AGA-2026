<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Comparativo: Professores 2B vs Censo Bauru 2022</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css" rel="stylesheet">
    <style>
        @import url('https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap');
        body {
            font-family: 'Inter', sans-serif;
            background-color: #f3f4f6;
        }
        .card-shadow {
            box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.1), 0 2px 4px -1px rgba(0, 0, 0, 0.06);
        }
    </style>
</head>
<body class="text-gray-800 p-4 sm:p-8">

    <div class="max-w-6xl mx-auto">
        <!-- Cabeçalho -->
        <header class="mb-8 text-center sm:text-left flex flex-col sm:flex-row justify-between items-center">
            <div>
                <h1 class="text-3xl font-bold text-indigo-700">Análise Demográfica</h1>
                <p class="text-gray-500 mt-2">Comparativo: Professores 2B (6 indivíduos) vs. Bauru (IBGE 2022)</p>
            </div>
            <div class="mt-4 sm:mt-0 bg-white p-3 rounded-lg shadow-sm border border-gray-200 flex items-center gap-3">
                <div class="bg-indigo-100 p-2 rounded-full text-indigo-600">
                    <i class="fas fa-users fa-lg"></i>
                </div>
                <div>
                    <p class="text-xs text-gray-500 font-semibold uppercase">Tamanho da Amostra</p>
                    <p class="text-xl font-bold text-gray-800">6 Professores</p>
                </div>
            </div>
        </header>

        <!-- Cards de Estatísticas Rápidas -->
        <div class="grid grid-cols-1 md:grid-cols-3 gap-6 mb-8">
            <div class="bg-white rounded-xl p-6 card-shadow border-t-4 border-blue-500 flex flex-col justify-center items-center text-center">
                <i class="fas fa-birthday-cake text-blue-500 text-3xl mb-3"></i>
                <h3 class="text-gray-500 font-medium text-sm">Média de Idade</h3>
                <div class="mt-2 flex items-baseline gap-2">
                    <span class="text-3xl font-bold text-gray-800">44,1</span>
                    <span class="text-gray-500 font-medium">anos</span>
                </div>
                <p class="text-xs text-gray-400 mt-2">Média de Bauru: ~36 anos</p>
            </div>

            <div class="bg-white rounded-xl p-6 card-shadow border-t-4 border-green-500 flex flex-col justify-center items-center text-center">
                <i class="fas fa-home text-green-500 text-3xl mb-3"></i>
                <h3 class="text-gray-500 font-medium text-sm">Moram em Casa</h3>
                <div class="mt-2 flex items-baseline gap-2">
                    <span class="text-3xl font-bold text-gray-800">83,3%</span>
                </div>
                <p class="text-xs text-gray-400 mt-2">5 de 6 moram em casas</p>
            </div>

            <div class="bg-white rounded-xl p-6 card-shadow border-t-4 border-teal-500 flex flex-col justify-center items-center text-center">
                <i class="fas fa-faucet text-teal-500 text-3xl mb-3"></i>
                <h3 class="text-gray-500 font-medium text-sm">Saneamento Adequado</h3>
                <div class="mt-2 flex items-baseline gap-2">
                    <span class="text-3xl font-bold text-gray-800">100%</span>
                </div>
                <p class="text-xs text-gray-400 mt-2">Bauru: 98,2% (Média IBGE)</p>
            </div>
        </div>

        <!-- Gráficos -->
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-8 mb-8">
            <!-- Gráfico de Gênero -->
            <div class="bg-white p-6 rounded-xl card-shadow">
                <h2 class="text-xl font-semibold mb-4 text-gray-700 border-b pb-2">Distribuição por Gênero (%)</h2>
                <div class="relative h-64 w-full">
                    <canvas id="genderChart"></canvas>
                </div>
                <p class="text-sm text-gray-500 mt-4 text-center">
                    A amostra dos professores é perfeitamente equilibrada, refletindo de perto a ligeira maioria feminina na população geral.
                </p>
            </div>

            <!-- Gráfico de Cor/Raça -->
            <div class="bg-white p-6 rounded-xl card-shadow">
                <h2 class="text-xl font-semibold mb-4 text-gray-700 border-b pb-2">Distribuição por Cor/Raça (%)</h2>
                <div class="relative h-64 w-full">
                    <canvas id="raceChart"></canvas>
                </div>
                <p class="text-sm text-gray-500 mt-4 text-center">
                    O grupo apresenta uma proporção ligeiramente maior de pessoas declaradas pretas e brancas em comparação com a média municipal.
                </p>
            </div>
        </div>

        <!-- Seção de Conclusão -->
        <div class="bg-white rounded-xl p-8 card-shadow mb-8 border-l-4 border-indigo-500">
            <h2 class="text-2xl font-bold text-gray-800 mb-4 flex items-center gap-2">
                <i class="fas fa-clipboard-check text-indigo-500"></i> Conclusão do Comparativo
            </h2>
            <p class="text-gray-600 leading-relaxed text-justify">
                Em síntese, a análise demográfica da amostra dos Professores 2B, embora restrita a seis indivíduos, reflete de maneira notável algumas das tendências macroscópicas da cidade de Bauru registradas no Censo 2022 do IBGE, como o equilíbrio na distribuição de gênero e a universalização do acesso ao saneamento básico adequado. No entanto, nota-se uma discrepância natural na média de idade — significativamente maior no grupo de professores (44,1 anos) em relação à média geral do município (cerca de 36 anos) —, o que é amplamente esperado para um recorte de profissionais já graduados e estabelecidos em suas carreiras. A distribuição étnico-racial da amostra também dialoga com a realidade bauruense, com predominância da população branca, seguida pelas populações parda e preta.
            </p>
        </div>

        <!-- Rodapé e Integrantes -->
        <footer class="mt-12 mb-6 text-center border-t border-gray-300 pt-6">
            <div class="mb-4">
                <h3 class="text-sm uppercase tracking-wider text-gray-500 font-bold mb-2">Integrantes do Grupo</h3>
                <p class="text-lg text-gray-800 font-medium">
                    Vitor Bispo, Nicolas Onorato, Caio Henrique, Nicolas Ribeiro e Matheus Felipe
                </p>
            </div>
            <div class="text-gray-400 text-xs mt-6 space-y-1">
                <p>Dados de Bauru baseados em estimativas e divulgações do Censo IBGE 2022.</p>
                <p>Desenvolvido como projeto de análise demográfica.</p>
            </div>
        </footer>
    </div>

    <script>
        // Configurações globais do Chart.js
        Chart.defaults.font.family = "'Inter', sans-serif";
        Chart.defaults.color = '#6b7280';
        Chart.defaults.scale.grid.color = '#f3f4f6';

        // 1. Gráfico de Gênero
        const ctxGender = document.getElementById('genderChart').getContext('2d');
        new Chart(ctxGender, {
            type: 'bar',
            data: {
                labels: ['Feminino', 'Masculino'],
                datasets: [
                    {
                        label: 'Professores 2B (%)',
                        data: [50, 50],
                        backgroundColor: 'rgba(79, 70, 229, 0.8)', // Indigo
                        borderColor: 'rgba(79, 70, 229, 1)',
                        borderWidth: 1,
                        borderRadius: 4
                    },
                    {
                        label: 'Bauru Censo 2022 (%)',
                        data: [51.5, 48.5],
                        backgroundColor: 'rgba(156, 163, 175, 0.6)', // Gray
                        borderColor: 'rgba(156, 163, 175, 1)',
                        borderWidth: 1,
                        borderRadius: 4
                    }
                ]
            },
            options: {
                responsive: true,
                maintainAspectRatio: false,
                plugins: {
                    legend: {
                        position: 'top',
                    },
                    tooltip: {
                        callbacks: {
                            label: function(context) {
                                return context.dataset.label + ': ' + context.parsed.y + '%';
                            }
                        }
                    }
                },
                scales: {
                    y: {
                        beginAtZero: true,
                        max: 100,
                        ticks: {
                            callback: function(value) {
                                return value + '%';
                            }
                        }
                    }
                }
            }
        });

        // 2. Gráfico de Raça/Etnia
        const ctxRace = document.getElementById('raceChart').getContext('2d');
        new Chart(ctxRace, {
            type: 'bar',
            data: {
                labels: ['Branca', 'Parda', 'Preta'],
                datasets: [
                    {
                        label: 'Professores 2B (%)',
                        data: [66.7, 16.7, 16.7],
                        backgroundColor: 'rgba(16, 185, 129, 0.8)', // Emerald
                        borderColor: 'rgba(16, 185, 129, 1)',
                        borderWidth: 1,
                        borderRadius: 4
                    },
                    {
                        label: 'Bauru Censo 2022 (%)',
                        data: [62.0, 28.0, 9.0], // Dados aproximados com base no IBGE 2022
                        backgroundColor: 'rgba(156, 163, 175, 0.6)', // Gray
                        borderColor: 'rgba(156, 163, 175, 1)',
                        borderWidth: 1,
                        borderRadius: 4
                    }
                ]
            },
            options: {
                responsive: true,
                maintainAspectRatio: false,
                plugins: {
                    legend: {
                        position: 'top',
                    },
                    tooltip: {
                        callbacks: {
                            label: function(context) {
                                return context.dataset.label + ': ' + context.parsed.y + '%';
                            }
                        }
                    }
                },
                scales: {
                    y: {
                        beginAtZero: true,
                        max: 100,
                        ticks: {
                            callback: function(value) {
                                return value + '%';
                            }
                        }
                    }
                }
            }
        });
    </script>
</body>
</html>
